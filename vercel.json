{
  "version": 2,
  "headers": [
    {
      "source": "/(.*).(webp|png|jpg|jpeg|gif|svg|ico|js|css|woff|woff2)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  {
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
